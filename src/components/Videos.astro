---
const videos = [
	{
		title: "KELU - Sesión en Vivo",
		description: "Live session grabada en Palacio Rioja.",
		url: "https://www.youtube.com/embed/0MGJD5zQip4"
	},
	{
		title: "Video Oficial - Dónde",
		description: "Single del próximo disco.",
		url: "https://www.youtube.com/embed/PK0levRbyE4"
	},
	{
		title: "Video Oficial - Salir a Jugar",
		description: "Single del próximo disco.",
		url: "https://www.youtube.com/embed/X5TjE9kvexY"
	}
];
---

<section id="videos" class="py-16 sm:py-24 md:py-32 relative overflow-hidden">
	<div class="absolute inset-0">
		<div class="absolute bottom-0 right-0 w-64 sm:w-96 h-64 sm:h-96 bg-red-500 rounded-full mix-blend-multiply filter blur-3xl opacity-10"></div>
	</div>

	<div class="max-w-6xl mx-auto px-4 relative z-10">
		
		<!-- Título -->
		<div class="text-center mb-12 sm:mb-16">
			<h2 class="text-4xl sm:text-5xl md:text-6xl font-black mb-4 sm:mb-6 gradient-text">
				Videos
			</h2>

			<p class="text-amber-200 text-base sm:text-lg">
				Disfruta de nuestros videos musicales y sesiones en vivo
			</p>
		</div>

		<!-- Grid videos -->
		<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
			{videos.map((video) => (
				<div class="rounded-2xl overflow-hidden bg-black/40 border border-amber-500/20 backdrop-blur-sm card-hover">

					<!-- Video -->
					<div class="aspect-video">
						<iframe
							class="w-full h-full"
							src={video.url}
							title={video.title}
							frameborder="0"
							allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
							allowfullscreen
						></iframe>
					</div>

					<!-- Información -->
					<div class="p-4 sm:p-5">
						<h3 class="text-amber-100 font-bold text-lg mb-2">
							{video.title}
						</h3>

						<p class="text-amber-200/70 text-sm leading-relaxed">
							{video.description}
						</p>
					</div>
				</div>
			))}
		</div>

		<!-- Botón canal -->
		<div class="text-center">
			<p class="text-amber-200 mb-4 sm:mb-6 text-base sm:text-lg">
				Suscríbete a nuestro canal de YouTube para más contenido exclusivo
			</p>

			<a
				href="https://www.youtube.com/@kelu.oficial"
				target="_blank"
				rel="noopener noreferrer"
				class="button-primary text-sm sm:text-base"
			>
				Ver en YouTube
			</a>
		</div>
	</div>
</section>