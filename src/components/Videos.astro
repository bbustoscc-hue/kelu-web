---
---

<section id="videos" class="py-32 relative overflow-hidden">
	<div class="absolute inset-0">
		<div class="absolute bottom-0 right-0 w-96 h-96 bg-red-500 rounded-full mix-blend-multiply filter blur-3xl opacity-10"></div>
	</div>

	<div class="max-w-6xl mx-auto px-4 relative z-10">
		<div class="text-center mb-16">
			<h2 class="text-5xl md:text-6xl font-black mb-6 gradient-text">
				Videos
			</h2>
			<p class="text-gray-400 text-lg">
				Disfruta de nuestros videos musicales y behind the scenes
			</p>
		</div>

		<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
			{[1, 2, 3].map((i) => (
				<div class="group relative overflow-hidden rounded-2xl aspect-video bg-slate-800 cursor-pointer card-hover">
					<div class="absolute inset-0 bg-gradient-to-br from-slate-800 to-slate-900 flex items-center justify-center">
						<div class="flex flex-col items-center gap-4">
							<div class="w-16 h-16 bg-gradient-to-br from-red-500 to-pink-500 rounded-full flex items-center justify-center group-hover:scale-110 transition-transform shadow-lg">
								<svg class="w-8 h-8 text-white ml-1" fill="currentColor" viewBox="0 0 20 20">
									<path d="M6.3 2.841A1.5 1.5 0 004 4.11V15.89a1.5 1.5 0 002.3 1.269l9.344-5.89a1.5 1.5 0 000-2.538L6.3 2.84z"/>
								</svg>
							</div>
							<span class="text-gray-400 font-medium">Video {i}</span>
						</div>
					</div>
					<div class="absolute inset-0 bg-black/0 group-hover:bg-black/40 transition-colors duration-300"></div>
					<div class="absolute inset-0 border-2 border-red-500 opacity-0 group-hover:opacity-100 rounded-2xl transition-opacity"></div>
				</div>
			))}
		</div>

		<div class="text-center">
			<p class="text-gray-400 mb-6 text-lg">
				Suscríbete a nuestro canal de YouTube para más contenido exclusivo
			</p>
			<a href="#" class="button-primary">
				Ver en YouTube
			</a>
		</div>
	</div>
</section>