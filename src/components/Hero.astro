---
---

<section class="relative min-h-screen flex items-center justify-end overflow-hidden pt-20 bg-black">
	<!-- Imagen de fondo -->
	<div 
		class="absolute inset-0 bg-contain bg-no-repeat"
		style="background-image: url('/images/banda.jpg'); background-position: left center;"
	>
		<!-- Overlay oscuro con gradiente hacia la derecha -->
		<div 
			class="absolute inset-0"
			style="background: linear-gradient(to right, transparent 0%, transparent 40%, rgba(0,0,0,0.95) 60%, rgba(0,0,0,1) 100%);"
		></div>
	</div>

	<!-- Contenido alineado a la derecha -->
	<div class="relative z-10 text-left px-6 md:px-12 max-w-2xl mr-0 md:mr-12 py-12">
		<h1 class="text-6xl md:text-8xl font-black mb-6 text-amber-300 animate-fade-in-up text-shadow" style="animation-delay: 0.2s;">
			KELU
		</h1>

		<p class="text-xl md:text-3xl text-amber-200 mb-6 font-bold animate-fade-in-up" style="animation-delay: 0.4s;">
			Música que conecta almas
		</p>

		<p class="text-base md:text-lg text-amber-100 mb-10 leading-relaxed animate-fade-in-up" style="animation-delay: 0.6s;">
			Una experiencia musical única donde la tradición del reggae se encuentra con innovación, autenticidad y un sonido que trasciende fronteras
		</p>

		<div class="flex gap-4 flex-wrap animate-fade-in-up" style="animation-delay: 0.8s;">
			<a href="#spotify" class="button-primary">
				Escuchar ahora
			</a>
			<a href="#gallery" class="button-secondary">
				Explorar galería
			</a>
		</div>

		<!-- Marquee + Próxima fecha -->
		<div class="mt-12 w-full animate-fade-in-up" style="animation-delay: 1s;">
			<!-- Marquee animado -->
			<div class="overflow-hidden bg-amber-900/20 backdrop-blur-sm border border-amber-700/30 rounded-xl p-4 mb-6">
				<div class="flex animate-marquee whitespace-nowrap">
					<span class="text-amber-300 font-bold text-lg mx-4">PRÓXIMO SHOW:</span>
					<span class="text-amber-200 text-lg mx-4">5 JUNIO - LANZAMIENTO "SALIR A JUGAR"</span>
					<span class="text-amber-300 font-bold text-lg mx-4"> PRÓXIMO SHOW:</span>
					<span class="text-amber-200 text-lg mx-4">5 JUNIO - LANZAMIENTO "SALIR A JUGAR"</span>
				</div>
			</div>
			
			<!-- Información de la próxima fecha -->
			<div class="glass-effect p-6 rounded-xl text-center">
				<div class="text-sm text-amber-400 font-semibold tracking-widest mb-2">PRÓXIMA PRESENTACIÓN</div>
				<div class="text-3xl md:text-4xl font-bold text-amber-300 mb-2">5 DE JUNIO</div>
				<div class="text-lg text-amber-200">Lanzamiento "Salir a Jugar" • 20:00 hrs</div>
				<a href="#tickets" class="inline-block mt-4 px-4 py-2 bg-amber-500/20 border border-amber-500 text-amber-300 hover:bg-amber-500/30 rounded-lg transition-all">
					Conseguir entradas →
				</a>
			</div>
		</div>
	</div>

	<!-- Scroll indicator -->
	<div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 animate-bounce">
		<svg class="w-6 h-6 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
			<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
		</svg>
	</div>
</section>