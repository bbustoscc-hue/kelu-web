---
---

<section class="relative min-h-screen flex flex-col md:flex-row items-center justify-center md:justify-between overflow-hidden bg-black">
	<!-- Imagen de fondo (desktop) -->
	<div 
		class="hidden md:flex w-1/2 h-screen items-center justify-center bg-cover bg-center relative"
		style="background-image: url('/images/banda.jpg'); background-position: left center;"
	>
		<!-- Gradiente para mezclar imagen con contenido -->
		<div 
			class="absolute inset-0"
			style="background: linear-gradient(to right, rgba(0,0,0,0.2) 0%, rgba(0,0,0,0.5) 40%, rgba(0,0,0,0.8) 70%, rgba(0,0,0,1) 100%);"
		></div>
		<!-- Gradiente adicional radial para efecto suave -->
		<div 
			class="absolute inset-0"
			style="background: radial-gradient(ellipse at right center, transparent 0%, rgba(0,0,0,0.3) 100%);"
		></div>
	</div>

	<!-- Contenido -->
	<div class="relative z-10 w-full md:w-1/2 px-4 sm:px-6 md:px-12 py-12 sm:py-16 md:py-20 flex flex-col items-center md:items-start">
		<h1 class="text-5xl sm:text-6xl md:text-8xl font-black mb-3 sm:mb-4 md:mb-6 text-amber-300 text-center md:text-left animate-fade-in-up text-shadow" style="animation-delay: 0.2s;">
			KELU
		</h1>

		<!-- Imagen móvil después del título -->
		<div 
			class="w-full h-64 sm:h-80 md:hidden bg-cover bg-center rounded-lg mb-6 sm:mb-8 animate-fade-in-up"
			style="background-image: url('/images/banda.jpg'); animation-delay: 0.3s;"
		></div>

		<p class="text-lg sm:text-2xl md:text-3xl text-amber-200 mb-3 sm:mb-4 md:mb-6 font-bold text-center md:text-left animate-fade-in-up" style="animation-delay: 0.4s;">
			Música que conecta almas
		</p>

		<p class="text-sm sm:text-base md:text-lg text-amber-100 mb-6 sm:mb-8 md:mb-10 leading-relaxed text-center md:text-left max-w-md md:max-w-none animate-fade-in-up" style="animation-delay: 0.6s;">
			Una experiencia musical única donde la tradición del reggae se encuentra con innovación, autenticidad y un sonido que trasciende fronteras
		</p>

		<!-- Botones -->
		<div class="flex gap-3 sm:gap-4 flex-wrap justify-center md:justify-start w-full animate-fade-in-up" style="animation-delay: 0.8s;">
			<a href="#spotify" class="button-primary">
				Escuchar ahora
			</a>
			<a href="#gallery" class="button-secondary">
				Explorar galería
			</a>
		</div>

		<!-- Próxima fecha -->
		<div class="mt-10 sm:mt-12 md:mt-14 w-full max-w-lg animate-fade-in-up" style="animation-delay: 1s;">
			<!-- Marquee animado -->
			<div class="overflow-hidden bg-amber-900/20 backdrop-blur-sm border border-amber-700/30 rounded-lg p-3 sm:p-4 mb-4">
				<div class="flex animate-marquee whitespace-nowrap">
					<span class="text-amber-300 font-bold text-xs sm:text-sm mx-3 sm:mx-4">PRÓXIMO SHOW:</span>
					<span class="text-amber-200 text-xs sm:text-sm mx-3 sm:mx-4">5 JUNIO - LANZAMIENTO "SALIR A JUGAR"</span>
					<span class="text-amber-300 font-bold text-xs sm:text-sm mx-3 sm:mx-4">PRÓXIMO SHOW:</span>
					<span class="text-amber-200 text-xs sm:text-sm mx-3 sm:mx-4">5 JUNIO - LANZAMIENTO "SALIR A JUGAR"</span>
				</div>
			</div>

			<!-- Información de la próxima fecha -->
			<div class="glass-effect p-4 sm:p-6 rounded-lg text-center">
				<div class="text-xs sm:text-sm text-amber-400 font-semibold tracking-widest mb-2">PRÓXIMA PRESENTACIÓN</div>
				<div class="text-2xl sm:text-3xl md:text-4xl font-bold text-amber-300 mb-2">5 DE JUNIO</div>
				<div class="text-xs sm:text-base md:text-lg text-amber-200 mb-3">Lanzamiento "Salir a Jugar" • 20:00 hrs</div>
				<a href="#tickets" class="inline-block px-4 sm:px-5 py-2 bg-amber-500/20 border border-amber-500 text-amber-300 hover:bg-amber-500/30 rounded-lg transition-all text-xs sm:text-sm font-semibold">
					Conseguir entradas →
				</a>
			</div>
		</div>
	</div>

	<!-- Scroll indicator -->
	<div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 animate-bounce hidden md:block">
		<svg class="w-6 h-6 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
			<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
		</svg>
	</div>
</section>