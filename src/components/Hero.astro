---
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden pt-20">
	<!-- Fondo animado -->
	<div class="absolute inset-0">
		<div class="absolute top-0 left-0 w-96 h-96 bg-amber-400 rounded-full mix-blend-multiply filter blur-3xl opacity-20 animate-float"></div>
		<div class="absolute top-40 right-0 w-96 h-96 bg-orange-500 rounded-full mix-blend-multiply filter blur-3xl opacity-20 animate-float" style="animation-delay: 2s;"></div>
		<div class="absolute bottom-0 left-1/2 w-96 h-96 bg-amber-400 rounded-full mix-blend-multiply filter blur-3xl opacity-20 animate-float" style="animation-delay: 4s;"></div>
	</div>

	<!-- Contenido -->
	<div class="relative z-10 text-center px-4 max-w-5xl mx-auto">
		<div class="mb-6 animate-fade-in-up">
			<span class="inline-block px-4 py-2 bg-amber-400/20 border border-amber-400/50 rounded-full text-amber-200 text-sm font-semibold mb-6">
				Reggae Moderno
			</span>
		</div>

		<h1 class="text-7xl md:text-9xl font-black mb-6 gradient-text animate-fade-in-up" style="animation-delay: 0.2s;">
			KELU
		</h1>

		<p class="text-2xl md:text-4xl text-amber-200 mb-8 font-bold animate-fade-in-up" style="animation-delay: 0.4s;">
			Música que conecta almas
		</p>

		<p class="text-lg md:text-xl text-amber-100 mb-12 max-w-2xl mx-auto leading-relaxed animate-fade-in-up" style="animation-delay: 0.6s;">
			Una experiencia musical única donde la tradición del reggae se encuentra con innovación, autenticidad y un sonido que trasciende fronteras
		</p>

		<div class="flex gap-6 justify-center flex-wrap animate-fade-in-up" style="animation-delay: 0.8s;">
			<a href="#spotify" class="button-primary">
				Escuchar ahora
			</a>
			<a href="#gallery" class="button-secondary">
				Explorar galería
			</a>
		</div>

		<!-- Estadísticas -->
		<div class="mt-16 grid grid-cols-3 gap-4 md:gap-8 animate-fade-in-up" style="animation-delay: 1s;">
			<div class="glass-effect p-6 rounded-xl">
				<div class="text-3xl md:text-4xl font-bold gradient-text">10K+</div>
				<div class="text-sm text-amber-200 mt-2">Seguidores</div>
			</div>
			<div class="glass-effect p-6 rounded-xl">
				<div class="text-3xl md:text-4xl font-bold gradient-text">50+</div>
				<div class="text-sm text-amber-200 mt-2">Canciones</div>
			</div>
			<div class="glass-effect p-6 rounded-xl">
				<div class="text-3xl md:text-4xl font-bold gradient-text">100+</div>
				<div class="text-sm text-amber-200 mt-2">Shows</div>
			</div>
		</div>
	</div>

	<!-- Scroll indicator -->
	<div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 animate-bounce">
		<svg class="w-6 h-6 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
			<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
		</svg>
	</div>
</section>