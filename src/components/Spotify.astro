---
---

<section id="spotify" class="py-32 relative overflow-hidden">
	<div class="absolute inset-0">
		<div class="absolute top-1/2 left-1/2 w-96 h-96 bg-amber-400 rounded-full mix-blend-multiply filter blur-3xl opacity-10 -translate-x-1/2"></div>
	</div>

	<div class="max-w-6xl mx-auto px-4 relative z-10">
		<div class="text-center mb-16">
			<h2 class="text-5xl md:text-6xl font-black mb-6 gradient-text">
				Escúchanos
			</h2>
			<p class="text-amber-200 text-lg">
				Accede a toda nuestra discografía en Spotify
			</p>
		</div>

		<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
			<div class="space-y-6 order-2 lg:order-1">
				<div class="group glass-effect p-8 rounded-2xl hover:border-amber-400 transition cursor-pointer card-hover">
					<div class="flex items-start gap-4">
						<div class="w-12 h-12 bg-gradient-to-br from-amber-400 to-orange-500 rounded-lg flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition">
							<svg class="w-6 h-6 text-amber-50" fill="currentColor" viewBox="0 0 24 24">
								<path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/>
							</svg>
						</div>
						<div>
							<h3 class="text-xl font-bold text-amber-50 mb-2">En Spotify</h3>
							<p class="text-amber-200">Accede a toda nuestra discografía y sigue nuestras actualizaciones</p>
						</div>
					</div>
					<a href="#" class="button-primary mt-4 inline-block">
						Ir a Spotify
					</a>
				</div>

				<div class="group glass-effect p-8 rounded-2xl hover:border-amber-400 transition cursor-pointer card-hover">
					<div class="flex items-start gap-4">
						<div class="w-12 h-12 bg-gradient-to-br from-orange-500 to-blue-500 rounded-lg flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition">
							<svg class="w-6 h-6 text-amber-50" fill="currentColor" viewBox="0 0 24 24">
								<path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
							</svg>
						</div>
						<div>
							<h3 class="text-xl font-bold text-amber-50 mb-2">Nuevos estrenos</h3>
							<p class="text-amber-200">Descubre nuestras canciones más recientes y exclusivas</p>
						</div>
					</div>
					<a href="#" class="button-primary mt-4 inline-block">
						Ver estrenos
					</a>
				</div>

				<div class="group glass-effect p-8 rounded-2xl hover:border-amber-400 transition cursor-pointer card-hover">
					<div class="flex items-start gap-4">
						<div class="w-12 h-12 bg-gradient-to-br from-pink-500 to-purple-500 rounded-lg flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition">
							<svg class="w-6 h-6 text-amber-50" fill="currentColor" viewBox="0 0 24 24">
								<path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm3.5-9c.83 0 1.5-.67 1.5-1.5S16.33 8 15.5 8 14 8.67 14 9.5s.67 1.5 1.5 1.5zm-7 0c.83 0 1.5-.67 1.5-1.5S9.33 8 8.5 8 7 8.67 7 9.5 7.67 11 8.5 11zm3.5 6.5c2.33 0 4.31-1.46 5.11-3.5H6.89c.8 2.04 2.78 3.5 5.11 3.5z"/>
							</svg>
						</div>
						<div>
							<h3 class="text-xl font-bold text-amber-50 mb-2">Suscríbete</h3>
							<p class="text-amber-200">No te pierdas ninguna actualización de KELU</p>
						</div>
					</div>
					<a href="#" class="button-primary mt-4 inline-block">
						Suscribirse
					</a>
				</div>
			</div>

			<div class="order-1 lg:order-2 flex justify-center">
				<div class="relative group">
					<div class="absolute -inset-1 bg-gradient-to-r from-amber-400 to-orange-500 rounded-2xl blur-2xl opacity-25 group-hover:opacity-75 transition duration-1000"></div>
					<div class="relative w-full max-w-sm aspect-square bg-gradient-to-br from-amber-50 to-orange-100 rounded-2xl overflow-hidden shadow-2xl flex items-center justify-center">
						<div class="text-center">
							<svg class="w-24 h-24 text-amber-400 mx-auto mb-4 opacity-50" fill="currentColor" viewBox="0 0 24 24">
								<path d="M12 3v9.28c-.47-.46-1.12-.74-1.84-.74-1.49 0-2.7 1.21-2.7 2.7 0 1.49 1.21 2.7 2.7 2.7 1.49 0 2.7-1.21 2.7-2.7V7h4V3h-4z"/>
							</svg>
							<p class="text-amber-200">Spotify Player</p>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>