---
---

<section id="spotify" class="py-16 sm:py-24 md:py-32 relative overflow-hidden">
	<!-- Fondo -->
	<div class="absolute inset-0">
		<div class="absolute top-1/2 left-1/2 w-64 sm:w-96 h-64 sm:h-96 bg-green-500 rounded-full mix-blend-multiply filter blur-3xl opacity-10 -translate-x-1/2 -translate-y-1/2"></div>
	</div>

	<div class="max-w-6xl mx-auto px-4 relative z-10">
		
		<!-- Título -->
		<div class="text-center mb-12 sm:mb-16">
			<h2 class="text-4xl sm:text-5xl md:text-6xl font-black mb-4 sm:mb-6 gradient-text">
				Escúchanos
			</h2>

			<p class="text-amber-200 text-base sm:text-lg max-w-2xl mx-auto">
				Escucha los últimos lanzamientos y novedades de KELU directamente en Spotify.
			</p>
		</div>

		<!-- Contenido -->
		<div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
			
			<!-- Texto -->
			<div>
				<div class="glass-effect p-6 sm:p-8 rounded-2xl border border-green-500/20">
					
					<h3 class="text-2xl sm:text-3xl font-bold text-amber-50 mb-4">
						KELU en Spotify
					</h3>

					<p class="text-amber-200 leading-relaxed mb-6">
						Sigue nuestro perfil para escuchar nuestra música y mantenerte al tanto de los nuevos lanzamientos.
					</p>

					<a
						href="https://open.spotify.com/artist/2toaxFRJmPh6ZMzORcgL1Z"
						target="_blank"
						rel="noopener noreferrer"
						class="button-primary inline-block"
					>
						Escuchar en Spotify
					</a>
				</div>
			</div>

			<!-- Spotify Embed -->
			<div class="relative">
				<div class="absolute -inset-2 bg-gradient-to-r from-green-500 to-emerald-400 rounded-3xl blur-2xl opacity-20"></div>

				<div class="relative glass-effect rounded-3xl p-4 border border-green-500/20">
					<iframe
						style="border-radius:12px"
						src="https://open.spotify.com/embed/artist/2toaxFRJmPh6ZMzORcgL1Z?utm_source=generator"
						width="100%"
						height="352"
						frameborder="0"
						allowfullscreen=""
						allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
						loading="lazy"
					></iframe>
				</div>
			</div>
		</div>
	</div>
</section>