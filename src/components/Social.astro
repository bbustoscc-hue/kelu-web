---
const socials = [
	{
		name: 'Instagram',
		url: 'https://instagram.com/kelu.oficial',
		color: 'hover:border-pink-500/50',
		type: 'instagram'
	},
	{
		name: 'Facebook',
		url: 'https://facebook.com/',
		color: 'hover:border-blue-500/50',
		type: 'facebook'
	},
	{
		name: 'YouTube',
		url: 'https://youtube.com/@kelu.oficial',
		color: 'hover:border-red-500/50',
		type: 'youtube'
	},
	{
		name: 'TikTok',
		url: 'https://tiktok.com/',
		color: 'hover:border-white/40',
		type: 'tiktok'
	}
];
---

<section id="social" class="py-16 sm:py-24 md:py-32 relative overflow-hidden">

	<!-- Fondo -->
	<div class="absolute inset-0">
		<div class="absolute top-1/4 left-0 w-72 h-72 bg-purple-500 rounded-full blur-3xl opacity-10"></div>
		<div class="absolute bottom-1/4 right-0 w-72 h-72 bg-amber-400 rounded-full blur-3xl opacity-10"></div>
	</div>

	<div class="max-w-5xl mx-auto px-4 relative z-10">

		<!-- Header -->
		<div class="text-center mb-12">
			<h2 class="text-4xl sm:text-5xl md:text-6xl font-black mb-4 gradient-text">
				Síguenos
			</h2>

			<p class="text-amber-200 text-base sm:text-lg">
				Conecta con KELU en redes sociales
			</p>
		</div>

		<!-- Redes -->
		<div class="grid grid-cols-2 sm:grid-cols-4 gap-4 sm:gap-6">
			{socials.map((social) => (
				<a
					href={social.url}
					target="_blank"
					rel="noopener noreferrer"
					class={`group glass-effect border border-white/10 ${social.color} rounded-2xl p-5 sm:p-6 flex flex-col items-center justify-center gap-3 transition-all duration-300 hover:-translate-y-1`}
				>

					<!-- Instagram -->
					{social.type === 'instagram' && (
						<svg viewBox="0 0 24 24" fill="currentColor" class="w-7 h-7 text-amber-50 group-hover:scale-110 transition-transform">
							<path d="M7.75 2C4.574 2 2 4.574 2 7.75v8.5C2 19.426 4.574 22 7.75 22h8.5C19.426 22 22 19.426 22 16.25v-8.5C22 4.574 19.426 2 16.25 2h-8.5zm0 2h8.5A3.75 3.75 0 0120 7.75v8.5A3.75 3.75 0 0116.25 20h-8.5A3.75 3.75 0 014 16.25v-8.5A3.75 3.75 0 017.75 4zm8.75 1a1.25 1.25 0 100 2.5 1.25 1.25 0 000-2.5zM12 7a5 5 0 100 10 5 5 0 000-10zm0 2a3 3 0 110 6 3 3 0 010-6z"/>
						</svg>
					)}

					<!-- Facebook -->
					{social.type === 'facebook' && (
						<svg viewBox="0 0 24 24" fill="currentColor" class="w-7 h-7 text-amber-50 group-hover:scale-110 transition-transform">
							<path d="M22 12a10 10 0 10-11.563 9.875v-6.987H7.898V12h2.539V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46H15.19c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.888H13.56v6.987A10 10 0 0022 12z"/>
						</svg>
					)}

					<!-- YouTube -->
					{social.type === 'youtube' && (
						<svg viewBox="0 0 24 24" fill="currentColor" class="w-7 h-7 text-amber-50 group-hover:scale-110 transition-transform">
							<path d="M23.498 6.186a2.997 2.997 0 00-2.11-2.12C19.505 3.5 12 3.5 12 3.5s-7.505 0-9.389.566a2.997 2.997 0 00-2.11 2.12A31.17 31.17 0 000 12a31.17 31.17 0 00.39 5.814 2.997 2.997 0 002.11 2.12C4.495 20.5 12 20.5 12 20.5s7.505 0 9.389-.566a2.997 2.997 0 002.11-2.12A31.17 31.17 0 0024 12a31.17 31.17 0 00-.502-5.814zM9.75 15.568V8.432L15.818 12 9.75 15.568z"/>
						</svg>
					)}

					<!-- TikTok -->
					{social.type === 'tiktok' && (
						<svg viewBox="0 0 24 24" fill="currentColor" class="w-7 h-7 text-amber-50 group-hover:scale-110 transition-transform">
							<path d="M19.589 6.686a4.793 4.793 0 01-3.77-4.115V2h-3.193v12.138a2.9 2.9 0 11-2.9-2.9c.288 0 .567.043.832.122V8.103a6.09 6.09 0 00-.832-.057A6.094 6.094 0 1015.82 14.14V8.813a7.96 7.96 0 004.68 1.513V7.133c-.318 0-.63-.15-.911-.447z"/>
						</svg>
					)}

					<span class="text-sm sm:text-base font-medium text-amber-100">
						{social.name}
					</span>
				</a>
			))}
		</div>
	</div>
</section>