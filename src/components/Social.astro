---
---

<section id="social" class="py-32 relative overflow-hidden">
	<div class="absolute inset-0">
		<div class="absolute top-1/4 left-0 w-96 h-96 bg-purple-500 rounded-full mix-blend-multiply filter blur-3xl opacity-10"></div>
		<div class="absolute bottom-1/4 right-0 w-96 h-96 bg-amber-400 rounded-full mix-blend-multiply filter blur-3xl opacity-10"></div>
	</div>

	<div class="max-w-6xl mx-auto px-4 relative z-10">
		<div class="text-center mb-16">
			<h2 class="text-5xl md:text-6xl font-black mb-6 gradient-text">
				Síguenos
			</h2>
			<p class="text-amber-200 text-lg">
				Mantente conectado con KELU en todas tus redes favoritas
			</p>
		</div>

		<div class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-12">
			{[
				{ name: 'Instagram', icon: '📷', url: '#', gradient: 'from-orange-400 to-yellow-600' },
				{ name: 'Facebook', icon: 'f', url: '#', gradient: 'from-amber-400 to-orange-400' },
				{ name: 'YouTube', icon: '▶️', url: '#', gradient: 'from-orange-400 to-amber-400' },
				{ name: 'TikTok', icon: '♪', url: '#', gradient: 'from-black to-gray-800' },
			].map((social) => (
				<a href={social.url} class={`group relative p-8 rounded-2xl bg-gradient-to-br ${social.gradient} overflow-hidden hover:shadow-2xl transition-all transform card-hover`}>
					<div class="absolute inset-0 bg-black/0 group-hover:bg-black/20 transition-colors"></div>
					<div class="relative z-10 text-center">
						<div class="text-5xl mb-4 group-hover:scale-110 transition-transform inline-block">{social.icon}</div>
						<h3 class="text-lg font-bold text-amber-50">{social.name}</h3>
						<p class="text-sm text-gray-200 opacity-0 group-hover:opacity-100 transition-opacity mt-3">
							Síguenos
						</p>
					</div>
				</a>
			))}
		</div>

		<div class="glass-effect p-8 rounded-2xl text-center">
			<h3 class="text-2xl font-bold text-amber-50 mb-4">Únete a nuestra comunidad</h3>
			<p class="text-amber-100 mb-6 max-w-2xl mx-auto">
				Sé parte de la familia KELU. Recibe noticias exclusivas, acceso a presales y contenido detrás de cámaras que solo los seguidores obtienen.
			</p>
			<a href="#" class="button-primary">
				Suscribirse
			</a>
		</div>
	</div>
</section>