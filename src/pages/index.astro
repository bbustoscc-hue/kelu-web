---
/* ===== PÁGINA PRINCIPAL (index.astro) =====
   Esta es la página de inicio del sitio.
   Importa todos los componentes y los renderiza en orden.

   ESTRUCTURA DE LA PÁGINA:
   1. Navigation - Menú superior (siempre visible)
   2. Hero - Sección principal de bienvenida
   3. About - Sección "Sobre KELU"
   4. Gallery - Galería de fotos
   5. Spotify - Sección de música/escucha
   6. Videos - Sección de videos
   7. Social - Redes sociales
   8. Footer - Pie de página

   MODIFICA: Agrega/elimina componentes aquí para cambiar la estructura
   ===== */

import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Gallery from '../components/Gallery.astro';
import Spotify from '../components/Spotify.astro';
import Videos from '../components/Videos.astro';
import Social from '../components/Social.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
	<!-- Navegación principal -->
	<Navigation />

	<!-- Contenido principal -->
	<main>
		<Hero />
		<About />
		<Gallery />
		<Spotify />
		<Videos />
		<Social />
	</main>

	<!-- Pie de página -->
	<Footer />
</Layout>
